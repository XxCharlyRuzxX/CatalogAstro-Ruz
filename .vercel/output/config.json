{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/mycategories/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/myproducts/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/panel/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/is-admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/categories/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/products/?$",
			"dest": "_render"
		},
		{
			"src": "^/catalog/?$",
			"dest": "_render"
		},
		{
			"src": "^/login-admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/myproducts/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}