---
import { Icon } from "astro-icon/components";
import CartBadge from "./react-components/CartBadge";
---

<header class="fixed top-0 z-50 w-full border-b border-[#D8D5CF] bg-[#F4F1EC]">
  <div
    class="mx-auto flex h-[64px] max-w-7xl items-center justify-between px-4 sm:px-6 lg:h-[72px] lg:px-8"
  >
    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href="/catalog"
        class="group inline-flex items-center gap-2 rounded-full px-3 py-2 text-[#2F3433] transition hover:bg-[#E9E5DF]"
        aria-label="Catálogo"
      >
        <Icon
          name="lucide:layout-grid"
          class="h-5 w-5 text-[#0F6C74] transition group-hover:scale-105"
        />
        <span class="hidden text-sm font-medium lg:inline">Catálogo</span>
      </a>

      <a
        href="/myproducts"
        class="group relative inline-flex items-center gap-2 rounded-full px-3 py-2 text-[#2F3433] transition hover:bg-[#E9E5DF]"
        aria-label="Carrito"
      >
      <span class="absolute right-0.5 top-0.5 md:right-0.5 md:top-0.5">
          <CartBadge client:load />
        </span>

        <Icon
          name="lucide:shopping-bag"
          class="h-5 w-5 text-[#0F6C74] transition group-hover:scale-105"
        />
        <span class="hidden text-sm font-medium lg:inline">Carrito</span>
      </a>
    </div>

    <a
      href="/"
      class="inline-flex items-center gap-2 text-[#1E1E1C]"
      aria-label="Inicio"
    >
      <Icon name="lucide:sparkles" class="h-5 w-5 text-[#0F6C74]"/>
      <span
        class="text-sm font-medium tracking-[0.12em] uppercase sm:text-base"
      >
        Liz Ruz
      </span>
    </a>

    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href="https://www.facebook.com/liz.ruz.5688"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-2 rounded-full px-3 py-2 text-[#2F3433] transition hover:bg-[#E9E5DF]"
        aria-label="Facebook"
      >
        <Icon
          name="mdi:facebook"
          class="h-5 w-5 text-[#0F6C74] transition group-hover:scale-105"
        />
        <span class="hidden text-sm font-medium lg:inline">Facebook</span>
      </a>

      <a
        href="https://www.instagram.com/lizruz2021/"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-2 rounded-full px-3 py-2 text-[#2F3433] transition hover:bg-[#E9E5DF]"
        aria-label="Instagram"
      >
        <Icon
          name="mdi:instagram"
          class="h-5 w-5 text-[#0F6C74] transition group-hover:scale-105"
        />
        <span class="hidden text-sm font-medium lg:inline">Instagram</span>
      </a>
    </div>
  </div>
</header>
