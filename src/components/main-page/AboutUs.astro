<section class="bg-[#2C3E3A] px-4 py-16 sm:px-6 lg:px-8">
  <div class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-10 lg:grid-cols-2">
    <div class="order-2 lg:order-1">
      <p class="mb-3 text-[11px] uppercase tracking-[0.35em] text-[#a3aba8] sm:text-xs">
        Acerca de nosotros
      </p>

      <h2 class="max-w-[14ch] text-3xl font-light leading-tight text-[#F1F6F6] sm:text-4xl">
        Una tienda pensada para destacar calidad, estilo y sencillez
      </h2>

      <p class="mt-5 text-sm leading-7 text-[#a3aba8] sm:text-base">
