generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model Category {
  id        String     @id @default(uuid())
  name      String
  productsCategory Product[] @relation("ProductCategories")
}

model Product {
  idProduct         String      @id @default(uuid())
  nameProduct       String
  imgProduct        String
  priceProduct      Float
  description       String
  brand             String
  stock             Int         @default(0)
  categoriesProduct Category[]  @relation("ProductCategories")

  @@map("products")
}
